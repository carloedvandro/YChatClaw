FROM node:20-alpine

WORKDIR /app/services/api-server

COPY services/api-server/package*.json ./
RUN apk add --no-cache git && npm install

COPY services/api-server/tsconfig.json ./
COPY services/api-server/src ./src
COPY shared /app/shared

RUN npx prisma generate --schema=/app/shared/prisma/schema.prisma --output-dir=./node_modules/.prisma/client

RUN npm run build

EXPOSE 3000

CMD ["node", "dist/index.js"]
