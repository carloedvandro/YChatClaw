FROM node:20-alpine

WORKDIR /app/services/whatsapp-gateway

COPY services/whatsapp-gateway/package*.json ./
RUN apk add --no-cache git chromium nss freetype freetype-dev harfbuzz ca-certificates ttf-freefont && npm install

COPY services/whatsapp-gateway/tsconfig.json ./
COPY services/whatsapp-gateway/src ./src
COPY shared /app/shared

RUN npm run build

EXPOSE 3003

CMD ["node", "dist/index.js"]
