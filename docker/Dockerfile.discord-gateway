FROM node:20-alpine

WORKDIR /app/services/discord-gateway

COPY services/discord-gateway/package*.json ./
RUN apk add --no-cache git && npm install -g prisma@6.0.0 @prisma/client@6.0.0 && npm install

COPY services/discord-gateway/tsconfig.json ./
COPY services/discord-gateway/src ./src
COPY shared /app/shared

WORKDIR /app/services/discord-gateway
RUN npx prisma generate --schema=/app/shared/prisma/schema.prisma

RUN npm run build

CMD ["node", "dist/index.js"]
